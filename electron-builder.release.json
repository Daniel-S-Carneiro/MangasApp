{
  "extends": null,
  "appId": "com.seuprojeto.gerenciadormangas",
  "productName": "Gerenciador de Mangás",
  "directories": {
    "output": "dist_electron_release"
  },
  "files": ["electron/**/*", "frontend/dist/**/*"],
  "extraResources": [
    {
      "from": "backend/dist/app.exe",
      "to": "backend/app.exe"
    },
    {
      "from": "backend/data",
      "to": "backend/data",
      "filter": ["!**/*.db"]
    },
    {
      "from": "frontend/public/img",
      "to": "frontend/public/img",
      "filter": ["default.jpg", "!capa_*"]
    }
  ],
  "win": {
    "icon": "frontend/public/icon/manga.ico",
    "target": ["nsis", "portable"]
  }
}
